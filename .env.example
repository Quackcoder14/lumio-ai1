# LUMIO AI — Environment Configuration
# Copy this to .env.local and fill in your values

# =============================================
# REQUIRED: Gemini API Key
# Get free key at: https://aistudio.google.com
# =============================================
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# =============================================
# OPTIONAL: GitHub Integration (for real PR creation)
# Create token at: https://github.com/settings/tokens
# Needs: repo scope
# =============================================
GITHUB_ACCESS_TOKEN=your_github_token_here

# =============================================
# OPTIONAL: Infracost API Key (for real cost data)
# Get free key at: https://www.infracost.io/docs/
# =============================================
INFRACOST_API_KEY=your_infracost_api_key_here
